# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# ── Nodo Mempool ──────────────────────────────────────────────────────────────
# IP o hostname de tu Umbrel (puerto por defecto de Mempool: 3006)
MEMPOOL_URL=http://192.168.1.x:3006

# ── Webhook de fallback ───────────────────────────────────────────────────────
# Usado SOLO para direcciones que no tienen categoría asignada.
# Lo recomendado es configurar el webhook directamente en cada categoría:
#   docker exec mempool-watcher python manage.py category add <nombre> <url>
WEBHOOK_URL=
WEBHOOK_SECRET=

# ── Comportamiento ────────────────────────────────────────────────────────────
# Segundos entre re-sincronizaciones de la watchlist con la BD
# (permite agregar/quitar dirs en caliente sin reiniciar el contenedor)
WATCHLIST_SYNC=60

# Segundos entre reintentos de reconexión si el WebSocket cae
RECONNECT_DELAY=10

# Timeout para requests HTTP a los webhooks (segundos)
REQUEST_TIMEOUT=10
