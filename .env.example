# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# IP o hostname de tu Umbrel (puerto por defecto de Mempool: 3006)
MEMPOOL_URL=http://192.168.1.x:3006

# Tu endpoint IPN (debe responder 200 OK)
WEBHOOK_URL=https://tu-servidor.com/ipn/bitcoin

# Secreto HMAC-SHA256 para verificar la autenticidad de las peticiones
# Genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# Intervalo de polling en segundos (mínimo recomendado: 15)
POLL_INTERVAL=30

# Timeout para requests HTTP (segundos)
REQUEST_TIMEOUT=10
